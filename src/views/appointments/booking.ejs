<%- include('../partials/header') %>
<style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Inter',sans-serif;
}

body{
    background:#f7f8fb;
}

/* Card */

.card{
    border:none !important;
    border-radius:35px !important;
    overflow:hidden;
    background:white;
    box-shadow:
    0 10px 35px rgba(255, 255, 255, 0.05);
}

/* Header */

.card-header{
    background:linear-gradient(
        135deg,
        #ffffff,
        #2563eb
    ) !important;

    padding:30px !important;

    border:none !important;
}

.card-header h4{

    font-size:28px;

    font-weight:800;

    margin:0;

}

/* Body */

.card-body{

    padding:40px !important;

}

/* Labels */

.form-label{

    font-size:14px;

    font-weight:700;

    color:#6b7280;

    margin-bottom:12px;

}

/* Inputs */

.form-control,
.form-select{

    border:none !important;

    background:#f8fafc !important;

    border-radius:20px !important;

    height:65px;

    padding:0 22px;

    font-size:15px;

    transition:.3s;

}

.form-control:focus,
.form-select:focus{

    box-shadow:
    0 0 0 4px rgba(37,99,235,.15) !important;

}

/* Reason box */

input[name="reason"]{

    height:65px;

}

/* Buttons */

.btn{

    border:none !important;

    border-radius:20px !important;

    padding:16px 28px;

    font-weight:700;

    transition:.3s;

}

.btn-primary{

    background:#82b5cb !important;

}

.btn-primary:hover{

    transform:translateY(-4px);

    background:#2563eb !important;

}

.btn-secondary{

    background:#e5e7eb !important;

    color:#111827 !important;

    margin-left:10px;

}

.btn-secondary:hover{

    transform:translateY(-4px);

}

/* Error */

.alert-danger{

    border:none;

    background:#fee2e2;

    color:#dc2626;

    border-radius:20px;

    padding:20px;

    font-weight:600;

}

/* Rows */

.row{

    margin-bottom:15px;

}

/* Form spacing */

.mb-3{

    margin-bottom:28px !important;

}

/* Responsive */

@media(max-width:768px){

    .card-body{

        padding:25px !important;

    }

}
</style>
<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card card-shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Book a New Appointment</h4>
      </div>
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form action="/api/appointments" method="POST">
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Patient *</label>
              <select name="patient" class="form-select" required>
                <option value="">-- Select Patient --</option>
                <% patients.forEach(p => { %>
                  <option value="<%= p._id %>"><%= p.firstName %> <%= p.lastName %> ( <%= p.email %> )</option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label">Doctor *</label>
              <select name="doctor" class="form-select" required>
                <option value="">-- Select Doctor --</option>
                <% doctors.forEach(d => { %>
                  <option value="<%= d._id %>">Dr. <%= d.firstName %> <%= d.lastName %> - <%= d.specialization %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="row mb-3">
            <div class="col-md-4">
              <label class="form-label">Date *</label>
              <input type="date" name="date" class="form-control" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">Start Time *</label>
              <input type="time" name="startTime" class="form-control" required>
            </div>
            <div class="col-md-4">
              <label class="form-label">End Time *</label>
              <input type="time" name="endTime" class="form-control" required>
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">Reason *</label>
            <input type="text" name="reason" class="form-control" required placeholder="e.g., Annual checkup, Fever, etc.">
          </div>
          <button type="submit" class="btn btn-primary"><i class="fas fa-save me-2"></i>Book Appointment</button>
          <a href="/dashboard" class="btn btn-secondary"><i class="fas fa-times me-2"></i>Cancel</a>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>