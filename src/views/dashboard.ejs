<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

:root{

--bg:#07111f;
--bg2:#0c1b2f;
--blue:#2563eb;
--white:#ffffff;
--text:#111827;
--muted:#6b7280;
--line:#e5e7eb;

}

body{

background:#f7f8fb;
overflow-x:hidden;

}

/* ===== MAIN LAYOUT ===== */

.dashboard{

display:flex;
min-height:100vh;

}

/* ===== SIDEBAR ===== */

.sidebar{

width:290px;

background:
linear-gradient(
180deg,
#07111f,
#0c1b2f
);

position:fixed;

left:0;
top:0;
bottom:0;

padding:40px 30px;

color:white;

overflow:hidden;

}

.sidebar::before{

content:"";

position:absolute;

width:500px;
height:500px;

background:#2563eb;

border-radius:50%;

filter:blur(180px);

top:-200px;
left:-200px;

opacity:.15;

}

.logo{

position:relative;

z-index:2;

margin-bottom:60px;

}

.logo h2{

font-size:28px;

font-weight:800;

letter-spacing:-1px;

}

.logo p{

margin-top:10px;

color:#cbd5e1;

font-size:14px;

}

/* ===== MENU ===== */

.menu{

position:relative;

z-index:2;

display:flex;

flex-direction:column;

gap:18px;

}

.menu a{

color:#d1d5db;

text-decoration:none;

padding:18px 22px;

border-radius:18px;

font-weight:500;

transition:.3s;

}

.menu a:hover{

background:
rgba(255,255,255,.08);

transform:translateX(6px);

}

.active-menu{

background:
rgba(255,255,255,.12);

}

/* ===== CONTENT ===== */

.content{

margin-left:290px;

width:100%;

padding:45px 50px;

}

/* ===== TOPBAR ===== */

.topbar{

display:flex;

justify-content:space-between;

align-items:center;

margin-bottom:50px;

}

.heading h1{

font-size:45px;

font-weight:800;

letter-spacing:-2px;

color:#111827;

}

.heading p{

margin-top:10px;

color:#6b7280;

line-height:1.8;

}

/* ===== PROFILE ===== */

.profile{

display:flex;

align-items:center;

gap:20px;

}

.avatar{

width:60px;
height:60px;

border-radius:50%;

background:#2563eb;

display:flex;

justify-content:center;
align-items:center;

font-size:22px;

font-weight:700;

color:white;

box-shadow:

0 15px 30px rgba(37,99,235,.3);

}

.user-info h4{

font-size:18px;

font-weight:700;

color:#111827;

}

.user-info p{

color:#6b7280;

margin-top:5px;

}

/* ===== ROLE BADGE ===== */

.role-badge{

display:inline-block;

margin-top:10px;

padding:10px 20px;

border-radius:40px;

background:#dbeafe;

color:#2563eb;

font-size:14px;

font-weight:700;

}

/* ===== SECTION TITLE ===== */

.section-title{

font-size:28px;

font-weight:800;

color:#111827;

margin-bottom:30px;

}

/* ===== GRID ===== */

.card-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(250px,1fr));

gap:30px;

}

/* ===== PREMIUM CARD ===== */

.card-box{

background:white;

padding:35px;

border-radius:30px;

box-shadow:

0 10px 35px rgba(0,0,0,.06);

transition:.4s;

position:relative;

overflow:hidden;

}

.card-box::before{

content:"";

position:absolute;

top:0;
left:0;

width:100%;
height:5px;

background:

linear-gradient(
90deg,
#2563eb,
#3b82f6
);

}

.card-box:hover{

transform:translateY(-10px);

box-shadow:

0 25px 50px rgba(0,0,0,.1);

}

/* ===== ICON ===== */

.card-icon{

width:80px;
height:80px;

border-radius:25px;

display:flex;

justify-content:center;
align-items:center;

font-size:32px;

margin-bottom:25px;

}

.blue{

background:#dbeafe;
color:#2563eb;

}

.green{

background:#d1fae5;
color:#10b981;

}

.orange{

background:#fef3c7;
color:#f59e0b;

}

.red{

background:#fee2e2;
color:#ef4444;

}

.card-box h2{

font-size:32px;

font-weight:800;

color:#111827;

}

.card-box p{

margin-top:12px;

line-height:1.8;

color:#6b7280;

}

.card-box a{

display:inline-block;

margin-top:20px;

text-decoration:none;

font-weight:700;

color:#2563eb;

}

/* animation */

.card-box{

animation:fadeUp .8s ease;

}

@keyframes fadeUp{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}

@media(max-width:1000px){

.sidebar{

display:none;

}

.content{

margin-left:0;

}

.topbar{

flex-direction:column;
align-items:flex-start;
gap:30px;

}

}

</style>

