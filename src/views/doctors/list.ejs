<style>

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

body{
background:#f7f8fb;
}

.topbar{

display:flex;
justify-content:space-between;
align-items:center;

margin-bottom:50px;

}

.topbar h1{

font-size:48px;
font-weight:800;
color:#111827;
letter-spacing:-2px;

}

.search{

margin-bottom:40px;

}

.search input{

width:100%;
height:65px;

padding:0 25px;

border:none;
outline:none;

background:white;

border-radius:25px;

box-shadow:
0 10px 35px rgba(0,0,0,.06);

font-size:16px;

}

.doctor-grid{

display:grid;

grid-template-columns:
repeat(auto-fit,minmax(350px,1fr));

gap:30px;

}

.doctor-card{

background:white;

padding:35px;

border-radius:35px;

box-shadow:
0 10px 35px rgba(0,0,0,.06);

transition:.4s;

position:relative;

overflow:hidden;

}

.doctor-card::before{

content:"";

position:absolute;

top:0;
left:0;

width:100%;
height:5px;

background:
linear-gradient(
90deg,
#2563eb,
#3b82f6
);

}

.doctor-card:hover{

transform:translateY(-10px);

box-shadow:
0 25px 50px rgba(0,0,0,.1);

}

.avatar{

width:80px;
height:80px;

border-radius:50%;

background:#2563eb;

display:flex;

justify-content:center;
align-items:center;

color:white;

font-size:28px;

font-weight:700;

margin-bottom:25px;

}

.doctor-card h2{

font-size:28px;

font-weight:800;

color:#111827;

}

.specialization{

margin-top:15px;

display:inline-block;

padding:12px 20px;

background:#dbeafe;

color:#2563eb;

border-radius:30px;

font-size:14px;

font-weight:700;

}

.info{

margin-top:25px;

line-height:1.9;

color:#6b7280;

}

.profile-btn{

display:inline-block;

margin-top:30px;

text-decoration:none;

font-weight:700;

color:#2563eb;

}

</style>

<div class="topbar">

<h1>
Doctors
</h1>

</div>

<div class="search">

<input
type="text"
placeholder="Search doctors by name or specialization...">

</div>

<div class="doctor-grid">

<% doctors.forEach(d=>{ %>

<div class="doctor-card">

<div class="avatar">

<%= d.firstName.charAt(0) %>

</div>

<h2>

Dr. <%= d.firstName %> <%= d.lastName %>

</h2>

<div class="specialization">

<%= d.specialization %>

</div>

<div class="info">

Experienced healthcare professional specializing in
<%= d.specialization %>.

</div>

<a href="#" class="profile-btn">

View Profile →

</a>

</div>

<% }) %>

</div>