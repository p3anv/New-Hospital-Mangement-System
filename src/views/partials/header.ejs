<!DOCTYPE html>
<html>
<head>

<title>Hospital Management System</title>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com">

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

body{

background:#f7f8fb;

padding-top:110px;

}

/* NAVBAR */

.navbar{

position:fixed;

top:20px;

left:50%;

transform:translateX(-50%);

width:95%;

max-width:1700px;

height:80px;

background:white;

border-radius:30px;

display:flex;

align-items:center;

justify-content:space-between;

padding:0 35px;

box-shadow:

0 10px 35px rgba(0,0,0,.05);

z-index:1000;

}

/* LEFT */

.nav-left{

display:flex;

align-items:center;

gap:50px;

}

.logo{

font-size:28px;

font-weight:800;

text-decoration:none;

color:#07111f;

}

.logo span{

color:#2563eb;

}

/* LINKS */

.nav-links{

display:flex;

gap:12px;

align-items:center;

}

.nav-links a{

text-decoration:none;

padding:14px 22px;

border-radius:18px;

font-weight:600;

color:#6b7280;

transition:.3s;

}

.nav-links a:hover{

background:#eef2ff;

color:#2563eb;

}

/* USER */

.user-box{

display:flex;

align-items:center;

gap:20px;

}

.avatar{

width:52px;

height:52px;

background:#2563eb;

border-radius:50%;

display:flex;

justify-content:center;

align-items:center;

font-size:20px;

font-weight:800;

color:white;

}

.user-info h4{

font-size:16px;

font-weight:700;

color:#111827;

}

.user-info p{

font-size:13px;

color:#6b7280;

margin-top:4px;

}

/* LOGOUT */

.logout-btn{

background:#07111f;

color:white;

padding:15px 25px;

border-radius:18px;

text-decoration:none;

font-weight:700;

transition:.3s;

}

.logout-btn:hover{

transform:translateY(-3px);

}


/* FLASH */

.flash{

background:white;

padding:20px 30px;

border-radius:25px;

box-shadow:

0 10px 35px rgba(0,0,0,.05);

margin-bottom:30px;

}

.success{

border-left:6px solid #16a34a;

}

.error{

border-left:6px solid #dc2626;

}


/* MOBILE */

@media(max-width:1200px){

.nav-links{

display:none;

}

}

</style>

</head>

<body>



<div class="navbar">

<div class="nav-left">

<a href="/dashboard" class="logo">

🏥 <span>HospitalMS</span>

</a>

<div class="nav-links">

<a href="/dashboard">

Dashboard

</a>

<a href="/api/patients">

Patients

</a>

<a href="/api/doctors">

Doctors

</a>

<a href="/api/appointments">

Appointments

</a>

<a href="/api/reports/generator">

Reports

</a>

<% if(user && user.role==="patient"){ %>

<a href="/my-appointments">

My Appointments

</a>

<% } %>

</div>

</div>



<div class="user-box">

<div class="avatar">

<%= user ? user.name.charAt(0).toUpperCase() : "G" %>

</div>

<div class="user-info">

<h4>

<%= user ? user.name : "Guest" %>

</h4>

<p>

<%= user ? user.role : "" %>

</p>

</div>

<a href="/auth/logout" class="logout-btn">

Logout

</a>

</div>

</div>



<div class="container">

<% if(success_msg){ %>

<div class="flash success">

<%= success_msg %>

</div>

<% } %>


<% if(error_msg){ %>

<div class="flash error">

<%= error_msg %>

</div>

<% } %>