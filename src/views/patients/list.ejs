<!DOCTYPE html>
<html>
<head><title>Patients</title></head>
<body>
  <h1>Patient List</h1>
  <a href="/patients/new">Register New</a>
  <ul>
    <% patients.forEach(p => { %>
      <li><a href="/api/patients/<%= p._id %>"><%= p.firstName %> <%= p.lastName %> - <%= p.email %></a></li>
    <% }) %>
  </ul>
</body>
</html>