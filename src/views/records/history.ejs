<!DOCTYPE html>
<html>
<head><title>Medical History</title></head>
<body>
  <h1>Medical History for <%= patient.firstName %> <%= patient.lastName %></h1>
  <a href="/patients/<%= patient._id %>">Back to Patient</a>
  <hr>
  <% if (records.length === 0) { %>
    <p>No records found.</p>
  <% } else { %>
    <% records.forEach(r => { %>
      <div style="border:1px solid #ccc; margin:10px; padding:10px;">
        <strong>Date:</strong> <%= r.visitDate.toDateString() %><br>
        <strong>Doctor:</strong> <%= r.doctor.firstName %> <%= r.doctor.lastName %><br>
        <strong>Diagnosis:</strong> <%= r.diagnosis %><br>
        <strong>Prescription:</strong>
        <ul>
          <% r.prescription.forEach(p => { %>
            <li><%= p.medicine %> - <%= p.dosage %> ( <%= p.frequency %> )</li>
          <% }) %>
        </ul>
        <strong>Notes:</strong> <%= r.notes || 'N/A' %>
      </div>
    <% }) %>
  <% } %>
</body>
</html>