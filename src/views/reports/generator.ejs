<script>

//
// ======================
// ADD MEDICINE
// ======================
//

let prescriptionCount = 1;

function addMedicineRow(){

const container =
document.getElementById("prescriptionContainer");

const div =
document.createElement("div");

div.className = "medicine-row";

div.innerHTML = `

<input
type="text"
name="prescription_medicine_${prescriptionCount}"
placeholder="Medicine">

<input
type="text"
name="prescription_dosage_${prescriptionCount}"
placeholder="Dosage">

<input
type="text"
name="prescription_frequency_${prescriptionCount}"
placeholder="Frequency">

<input
type="text"
name="prescription_duration_${prescriptionCount}"
placeholder="Duration">

<button
type="button"
class="remove-row">

✕

</button>

`;

container.appendChild(div);

prescriptionCount++;

}


document.addEventListener("click",(e)=>{

if(e.target.classList.contains("remove-row")){

e.target.parentElement.remove();

}

});


//
// ======================
// BUTTON
// ======================
//

const addButton =
document.getElementById("addMedicine");

if(addButton){

addButton.addEventListener(

"click",

addMedicineRow

);

}



//
// ======================
// CARD ANIMATION
// ======================
//

const cards =
document.querySelectorAll(

".medicine-card,.history-card,.stat-box"

);

cards.forEach(

(card,index)=>{

card.style.opacity="0";

card.style.transform="translateY(30px)";

setTimeout(()=>{

card.style.transition=".6s";

card.style.opacity="1";

card.style.transform="translateY(0px)";

},index*100);

}

);


//
// ======================
// COUNTERS
// ======================
//

function animateCounter(

element,
target

){

let count = 0;

let speed = target / 60;

const interval = setInterval(()=>{

count += speed;

if(count >= target){

count = target;

clearInterval(interval);

}

element.innerText =
Math.floor(count);

},20);

}


document.querySelectorAll(

".stat-box h2"

).forEach(el=>{

const number =
parseInt(el.innerText);

if(!isNaN(number)){

animateCounter(el,number);

}

});



//
// ======================
// TOAST
// ======================
//

function showToast(message){

const toast =
document.createElement("div");

toast.className="toast";

toast.innerText=message;

document.body.appendChild(toast);

setTimeout(()=>{

toast.classList.add("show");

},100);

setTimeout(()=>{

toast.remove();

},3000);

}


//
// SUCCESS MESSAGE
//

<% if(success){ %>

showToast(

"<%= success %>"

);

<% } %>

</script>

