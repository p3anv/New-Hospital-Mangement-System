</style>
<div class="page-header">

    <div class="header-left">

        <h1>Medical Report Center</h1>

        <p>
            Generate patient reports, prescriptions and maintain visit history.
        </p>

    </div>

</div>



<!-- MAIN GRID -->

<div class="report-grid">




    <!-- ================= LEFT PANEL ================= -->

    <div class="left-panel">

        <div class="report-builder-card">

            <h2>Report Builder</h2>

            <% if(error){ %>

                <div class="error-box">
                    <%= error %>
                </div>

            <% } %>


            <% if(success){ %>

                <div class="success-box">
                    <%= success %>
                </div>

            <% } %>


            <form action="/api/reports/patient" method="GET">

                <!-- PATIENT -->

                <div class="form-group">

                    <label>Patient</label>

                    <select name="patientId" required>

                        <option value="">Select Patient</option>

                        <% patients.forEach(p=>{ %>

                            <option value="<%= p._id %>">

                                <%= p.firstName %> <%= p.lastName %>

                            </option>

                        <% }) %>

                    </select>

                </div>



                <!-- DOCTOR -->

                <div class="form-group">

                    <label>Doctor</label>

                    <% if(loggedInDoctor){ %>

                        <input
                        type="text"
                        disabled
                        value="Dr. <%= loggedInDoctor.firstName %> <%= loggedInDoctor.lastName %>">

                    <% } else { %>

                        <select name="doctorId">

                            <option>Select Doctor</option>

                            <% doctors.forEach(d=>{ %>

                                <option value="<%= d._id %>">

                                    Dr. <%= d.firstName %>
                                    <%= d.lastName %>

                                </option>

                            <% }) %>

                        </select>

                    <% } %>

                </div>



                <!-- DATE RANGE -->

                <div class="date-row">

                    <div class="form-group">

                        <label>Start Date</label>

                        <input type="date" name="startDate">

                    </div>


                    <div class="form-group">

                        <label>End Date</label>

                        <input type="date" name="endDate">

                    </div>

                </div>



                <% if(user && user.role==="doctor"){ %>

                <!-- VISIT DETAILS -->

                <h3>Visit Details</h3>

                <div class="form-group">

                    <label>Diagnosis</label>

                    <input
                    type="text"
                    name="diagnosis"
                    placeholder="Acute Bronchitis">

                </div>


                <div class="form-group">

                    <label>Notes</label>

                    <textarea
                    rows="5"
                    name="notes"></textarea>

                </div>



                <!-- PRESCRIPTIONS -->

                <h3>Prescriptions</h3>

                <div id="prescriptionContainer">

                    <div class="medicine-row">

                        <input
                        type="text"
                        name="prescription_medicine_0"
                        placeholder="Medicine">

                        <input
                        type="text"
                        name="prescription_dosage_0"
                        placeholder="Dosage">

                        <input
                        type="text"
                        name="prescription_frequency_0"
                        placeholder="Frequency">

                        <input
                        type="text"
                        name="prescription_duration_0"
                        placeholder="Duration">

                    </div>

                </div>

                <button type="button" id="addMedicine">

                    Add Medicine

                </button>

                <% } %>


                <button type="submit">

                    Generate Report

                </button>

            </form>

        </div>

    </div>





    <!-- ================= RIGHT PANEL ================= -->

    <div class="right-panel">

        <% if(reportData){ %>

        <!-- PATIENT SUMMARY -->

        <div class="summary-card">

            <div class="patient-header">

                <div class="avatar">

                    <%= reportData.patient.firstName.charAt(0) %>

                </div>

                <div>

                    <h2>

                        <%= reportData.patient.firstName %>
                        <%= reportData.patient.lastName %>

                    </h2>

                    <p>Patient Summary</p>

                </div>

            </div>


            <!-- STATS -->

            <div class="stats-grid">

                <div class="stat-box">

                    <h4>Email</h4>

                    <p><%= reportData.patient.email %></p>

                </div>

                <div class="stat-box">

                    <h4>Phone</h4>

                    <p><%= reportData.patient.phone %></p>

                </div>

                <div class="stat-box">

                    <h4>Total Visits</h4>

                    <h2>

                        <%= reportData.summary.totalVisits %>

                    </h2>

                </div>

            </div>

        </div>



        <!-- DIAGNOSIS -->

        <div class="diagnosis-section">

            <h2>Diagnoses</h2>

            <div class="diagnosis-chips">

                <% reportData.summary.diagnoses.forEach(d=>{ %>

                    <div class="chip">

                        <%= d %>

                    </div>

                <% }) %>

            </div>

        </div>



        <!-- MEDICINES -->

        <div class="medicine-section">

            <h2>Prescriptions</h2>

            <div class="medicine-grid">

                <% reportData.summary.medicines.forEach(m=>{ %>

                    <div class="medicine-card">

                        <h3>

                            <%= m.medicine %>

                        </h3>

                        <p>

                            <%= m.dosage %>

                        </p>

                        <p>

                            <%= m.frequency %>

                        </p>

                    </div>

                <% }) %>

            </div>

        </div>



        <!-- VISIT HISTORY -->

        <div class="history-section">

            <h2>Visit History</h2>

            <% reportData.summary.records.forEach(r=>{ %>

                <div class="history-card">

                    <h3>

                        <%= r.diagnosis %>

                    </h3>

                    <p>

                        Dr.
                        <%= r.doctorInfo.firstName %>
                        <%= r.doctorInfo.lastName %>

                    </p>

                    <p>

                        <%= new Date(r.visitDate).toDateString() %>

                    </p>

                </div>

            <% }) %>

        </div>



        <!-- TIMELINE -->

        <div class="timeline-section">

<h2>Medical Timeline</h2>

<div class="timeline">

<% reportData.summary.records.forEach(r=>{ %>

<div class="timeline-item">

    <div class="timeline-dot"></div>

    <div class="timeline-card">

        <h3>

            <%= r.diagnosis %>

        </h3>

        <p>

            Dr.
            <%= r.doctorInfo.firstName %>
            <%= r.doctorInfo.lastName %>

        </p>

        <small>

            <%= new Date(r.visitDate).toDateString() %>

        </small>

    </div>

</div>

<% }) %>

</div>

</div>

<div class="health-summary">

    <div class="summary-overlay"></div>

    <div class="summary-content">

        <h2>Health Summary</h2>

        <p>

            Patient has completed
            <strong><%= reportData.summary.totalVisits %></strong>
            consultations and currently has

            <strong><%= reportData.summary.medicines.length %></strong>

            medications prescribed.

        </p>

    </div>

</div>

        <!-- ANALYTICS -->

        <div class="analytics-section">

            <h2>Analytics</h2>

        </div>
        <div class="analytics-section">

<h2>Analytics</h2>

<div class="analytics-grid">

    <div class="analytics-card">

        <h1>

            <%= reportData.summary.totalVisits %>

        </h1>

        <p>Total Visits</p>

    </div>


    <div class="analytics-card">

        <h1>

            <%= reportData.summary.diagnoses.length %>

        </h1>

        <p>Diagnoses</p>

    </div>


    <div class="analytics-card">

        <h1>

            <%= reportData.summary.medicines.length %>

        </h1>

        <p>Prescriptions</p>

    </div>


    <div class="analytics-card">

        <h1>

            <%= reportData.summary.records.length %>

        </h1>

        <p>Medical Records</p>

    </div>

</div>

</div>



        <!-- EXPORT -->

        <div class="export-section">

            <a
            href="/api/reports/download?patientId=<%= reportData.patient._id %>">

                Export PDF

            </a>

        </div>

        <% } else { %>

        <div class="empty-state">

            <h2>

                No Report Generated

            </h2>

            <p>

                Select a patient and generate a report.

            </p>

        </div>

        <% } %>

    </div>
    <div class="report-footer">

<h4>

Hospital Management System

</h4>

<p>

Enterprise Medical Report Center

</p>

</div>

</div>

<%- include('../partials/footer') %>