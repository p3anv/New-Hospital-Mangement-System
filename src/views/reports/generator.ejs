<!DOCTYPE html>
<html>
<head>
  <title>Report Generator</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 20px; }
    .report-box { border: 1px solid #ccc; padding: 20px; margin-top: 20px; background: #f9f9f9; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
    th { background: #f2f2f2; }
  </style>
</head>
<body>
  <h1>📊 Patient Report Generator</h1>
  <form action="/api/reports/patient" method="GET">
    <label>Patient:
      <select name="patientId" required>
        <option value="">-- Select --</option>
        <% patients.forEach(p => { %>
          <option value="<%= p._id %>"><%= p.firstName %> <%= p.lastName %></option>
        <% }) %>
      </select>
    </label><br><br>
    <label>Start Date: <input type="date" name="startDate"></label>
    <label>End Date: <input type="date" name="endDate"></label>
    <button type="submit">Generate</button>
  </form>

  <% if (reportData) { %>
    <div class="report-box">
      <h2>Report for <%= reportData.patient.firstName %> <%= reportData.patient.lastName %></h2>
      <p><strong>Email:</strong> <%= reportData.patient.email %></p>
      <p><strong>Total Visits:</strong> <%= reportData.summary.totalVisits %></p>
      
      <h3>Diagnoses</h3>
      <ul>
        <% reportData.summary.diagnoses.forEach(d => { %>
          <li><%= d %></li>
        <% }) %>
      </ul>
      
      <h3>Prescribed Medicines</h3>
      <ul>
        <% reportData.summary.medicines.forEach(m => { %>
          <li><%= m.medicine %> - <%= m.dosage %> (<%= m.frequency %>)</li>
        <% }) %>
      </ul>
      
      <h3>Visit Details</h3>
      <table>
        <thead><tr><th>Date</th><th>Doctor</th><th>Diagnosis</th></tr></thead>
        <tbody>
          <% reportData.summary.records.forEach(r => { %>
            <tr>
              <td><%= new Date(r.visitDate).toDateString() %></td>
              <td><%= r.doctorInfo.firstName %> <%= r.doctorInfo.lastName %></td>
              <td><%= r.diagnosis %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</body>
</html>